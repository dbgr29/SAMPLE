<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment" >

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.sample.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_checkupFragment"
            app:destination="@id/checkupFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />

        <action
            android:id="@+id/action_home_to_scan"
            app:destination="@id/scanFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />

        <action
            android:id="@+id/action_home_to_vitals"
            app:destination="@id/vitalsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />

        <action
            android:id="@+id/action_home_to_bloodChem"
            app:destination="@id/bloodChemFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />

        <action
            android:id="@+id/action_home_to_riskFactors"
            app:destination="@id/riskFactorsFragment"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/scanFragment"
        android:name="com.example.sample.ScanFragment"
        android:label="fragment_scan"
        tools:layout="@layout/fragment_scan" />

    <fragment
        android:id="@+id/checkupFragment"
        android:name="com.example.sample.CheckupFragment"
        android:label="Checkup"
        tools:layout="@layout/fragment_checkup" />

    <fragment
        android:id="@+id/vitalsFragment"
        android:name="com.example.sample.VitalsFragment"
        android:label="Record Vitals"
        tools:layout="@layout/fragment_vitals" />

    <fragment
        android:id="@+id/befastFragment"
        android:name="com.example.sample.BefastFragment"
        android:label="BE-FAST"
        tools:layout="@layout/fragment_befast" />

    <fragment
        android:id="@+id/bloodChemFragment"
        android:name="com.example.sample.BloodChemFragment"
        android:label="Blood Chemistry"
        tools:layout="@layout/fragment_blood_chem" />

    <fragment
        android:id="@+id/riskFactorsFragment"
        android:name="com.example.sample.RiskFactorsFragment"
        android:label="Risk Factors"
        tools:layout="@layout/fragment_risk_factors" />

</navigation>